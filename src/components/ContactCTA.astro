---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).contact;
const f = t.form;
---

<section id="contact" class="py-20 md:py-28 relative overflow-hidden" style="background: var(--color-primary);" aria-labelledby="contact-title">
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 70% at 50% 110%, rgba(202,138,4,0.12) 0%, transparent 70%);" aria-hidden="true"></div>

  <div class="container relative">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-start">

      <!-- Gauche -->
      <div>
        <span class="overline" style="color: #FCD34D;">{t.overline}</span>
        <h2 id="contact-title" class="mb-5" style="font-size: clamp(1.875rem, 4vw, 2.75rem); color: white; line-height: 1.15; letter-spacing: -0.025em;">
          {t.title}
        </h2>
        <p style="font-size: 1.0625rem; line-height: 1.75; color: rgba(255,255,255,0.68); margin-bottom: 2rem;">{t.subtitle}</p>

        <ul class="flex flex-col gap-4 list-none m-0 p-0">
          {t.promises.map(item => (
            <li class="flex items-center gap-3">
              <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0" style="background: rgba(202,138,4,0.2);" aria-hidden="true">
                <!-- Heroicons: check -->
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#FCD34D" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m4.5 12.75 6 6 9-13.5"/>
                </svg>
              </div>
              <span style="font-size: 0.9375rem; color: rgba(255,255,255,0.75);">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-10 pt-8" style="border-top: 1px solid rgba(255,255,255,0.12);">
          <p class="text-sm mb-4" style="color: rgba(255,255,255,0.45); letter-spacing: 0.08em; text-transform: uppercase; font-weight: 600;">{t.directLabel}</p>
          <a href="mailto:info@seopharmamontreal.com" class="flex items-center gap-3 text-base font-medium no-underline hover:opacity-80 transition-opacity" style="color: white;">
            <!-- Heroicons: envelope -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            info@seopharmamontreal.com
          </a>
          <a href={`tel:${t.phone}`} class="flex items-center gap-3 text-base font-medium no-underline hover:opacity-80 transition-opacity mt-3" style="color: white;">
            <!-- Heroicons: phone -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
            {t.phone}
          </a>
        </div>
      </div>

      <!-- Droite : formulaire -->
      <div class="rounded-2xl p-8" style="background: var(--color-surface); box-shadow: 0 25px 50px rgba(15,23,42,0.3);">
        <h3 class="mb-1.5" style="font-size: 1.25rem; color: var(--color-primary);">{f.title}</h3>
        <p class="mb-6 text-sm" style="color: var(--color-text-muted);">{f.subtitle}</p>

        <form name="contact" method="POST" data-netlify="true" novalidate class="flex flex-col gap-5" aria-label={f.title}>
          <input type="hidden" name="form-name" value="contact" />

          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="prenom" class="text-sm font-medium" style="color: var(--color-primary);">
                {f.prenom} <span style="color: var(--color-error);" aria-hidden="true">*</span>
              </label>
              <input type="text" id="prenom" name="prenom" required autocomplete="given-name"
                class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200"
                style="border-color: var(--color-border); color: var(--color-text);" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="nom" class="text-sm font-medium" style="color: var(--color-primary);">
                {f.nom} <span style="color: var(--color-error);" aria-hidden="true">*</span>
              </label>
              <input type="text" id="nom" name="nom" required autocomplete="family-name"
                class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200"
                style="border-color: var(--color-border); color: var(--color-text);" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="entreprise" class="text-sm font-medium" style="color: var(--color-primary);">
              {f.entreprise} <span style="color: var(--color-error);" aria-hidden="true">*</span>
            </label>
            <input type="text" id="entreprise" name="entreprise" required autocomplete="organization"
              class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200"
              style="border-color: var(--color-border); color: var(--color-text);" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium" style="color: var(--color-primary);">
              {f.email} <span style="color: var(--color-error);" aria-hidden="true">*</span>
            </label>
            <input type="email" id="email" name="email" required autocomplete="email"
              class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200"
              style="border-color: var(--color-border); color: var(--color-text);" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="secteur" class="text-sm font-medium" style="color: var(--color-primary);">{f.secteur}</label>
            <select id="secteur" name="secteur"
              class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200"
              style="border-color: var(--color-border); color: var(--color-text);">
              <option value="">—</option>
              {f.secteurOpts.map(opt => <option value={opt}>{opt}</option>)}
            </select>
          </div>

          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-sm font-medium" style="color: var(--color-primary);">{f.message}</label>
            <textarea id="message" name="message" rows="3" placeholder={f.messagePh}
              class="contact-input rounded-lg border px-4 py-3 text-base outline-none transition-all duration-200 resize-y"
              style="border-color: var(--color-border); color: var(--color-text); min-height: 100px;"></textarea>
          </div>

          <button type="submit" class="btn btn-primary btn-lg w-full justify-center mt-1">
            <!-- Heroicons: paper-airplane -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
            </svg>
            {f.submit}
          </button>
          <p class="text-xs text-center mt-1" style="color: var(--color-text-subtle);">{f.privacy}</p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-input:focus {
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.12);
  }
</style>
