---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).booking;
---

<section
  id="rendez-vous"
  class="py-20 md:py-28"
  style="background: var(--color-primary);"
  aria-labelledby="booking-title"
>
  <div
    class="absolute pointer-events-none"
    style="inset: 0; background: radial-gradient(ellipse 70% 50% at 50% 100%, rgba(202,138,4,0.1) 0%, transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="container relative">
    <div class="section-header" style="--section-header-color: white;">
      <span class="overline" style="color: #FCD34D;">{t.overline}</span>
      <h2
        id="booking-title"
        class="section-title"
        style="color: white;"
      >
        {t.title}
      </h2>
      <p
        class="section-lead"
        style="color: rgba(255,255,255,0.65);"
      >
        {t.lead}
      </p>
    </div>

    <!-- HubSpot Meetings Embed -->
    <div
      class="mx-auto rounded-2xl overflow-hidden"
      style="max-width: 820px; box-shadow: 0 24px 48px rgba(0,0,0,0.35);"
    >
      <!-- min-height reserves space before HubSpot injects the iframe → prevents CLS -->
      <div
        class="meetings-iframe-container"
        data-src="https://meetings-na3.hubspot.com/soulimane?embed=true"
        style="min-height: 700px;"
      ></div>
    </div>
  </div>
</section>

<!-- HubSpot chargé à l'approche de la section seulement : son bundle (~630 Ko JS)
     plombait TBT/LCP mobile quand il partait dès le parse, même en defer -->
<script>
  const bookingSection = document.getElementById('rendez-vous');
  let hsLoaded = false;
  const loadHubSpot = () => {
    if (hsLoaded) return;
    hsLoaded = true;
    const s = document.createElement('script');
    s.src = 'https://static.hsappstatic.net/MeetingsEmbed/ex/MeetingsEmbedCode.js';
    document.body.appendChild(s);
  };
  if (bookingSection && 'IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          loadHubSpot();
        }
      },
      { rootMargin: '800px 0px' }
    );
    io.observe(bookingSection);
  } else {
    loadHubSpot();
  }
</script>
