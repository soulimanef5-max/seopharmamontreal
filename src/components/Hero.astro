---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).hero;

const heroAlt = lang === 'fr'
  ? 'Consultant SEO/GEO travaillant sur une stratégie digitale pour le secteur pharmaceutique'
  : 'SEO/GEO consultant working on a digital strategy for the pharmaceutical sector';
---

<section
  class="relative overflow-hidden py-24 md:py-32"
  style="background: var(--color-primary);"
  aria-labelledby="hero-title"
>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 65% 60% at 70% 30%, rgba(202,138,4,0.14) 0%, transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="container relative">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Texte -->
      <div class="max-w-xl">
        <div class="badge-authority">
          <!-- Heroicons: sparkles -->
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#FCD34D" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>
          </svg>
          {t.badge}
        </div>

        <h1
          id="hero-title"
          class="text-white mb-6"
          style="font-size: clamp(2.25rem, 5.5vw, 3.5rem); line-height: 1.08; letter-spacing: -0.03em;"
        >
          {t.title1}<br />{t.title2}<br />
          <span style="color: var(--color-cta);">{t.title3}</span>
        </h1>

        <!-- Passage factuel extractible par les LLMs — ne pas retirer -->
        <p
          class="mb-4"
          style="font-size: 0.9375rem; line-height: 1.65; color: rgba(255,255,255,0.55); font-style: italic;"
        >
          {lang === 'fr'
            ? 'Soulimane Farah est consultant SEO/GEO spécialisé dans le secteur pharmaceutique canadien. Basé à Montréal, il accompagne les PME pharma, fabricants de PSN et de dispositifs médicaux dans leur visibilité sur Google et les intelligences artificielles génératives (ChatGPT, Perplexity, Claude, Gemini).'
            : 'Soulimane Farah is a SEO/GEO consultant specialized in the Canadian pharmaceutical sector. Based in Montréal, he helps pharma SMEs, NHP and medical device manufacturers improve their visibility on Google and generative AI platforms (ChatGPT, Perplexity, Claude, Gemini).'}
        </p>

        <p
          class="mb-10"
          style="font-size: clamp(1rem, 1.8vw, 1.125rem); line-height: 1.7; color: rgba(255,255,255,0.73);"
        >
          {t.subtitle}
        </p>

        <div class="flex flex-wrap gap-4 items-center">
          <a href="#contact" class="btn btn-primary btn-xl">
            <!-- Heroicons: phone -->
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
            {t.cta1}
          </a>
          <a href="#services" class="btn btn-ghost btn-xl">
            {t.cta2}
            <!-- Heroicons: arrow-right -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <div
          class="flex flex-wrap items-center gap-x-6 gap-y-3 mt-12"
          style="color: rgba(255,255,255,0.52); font-size: 0.8125rem;"
        >
          {[t.proof1, t.proof2, t.proof3].map((proof, i) => (
            <>
              {i > 0 && <div class="w-px h-4 hidden sm:block" style="background: rgba(255,255,255,0.18);" aria-hidden="true"></div>}
              <div class="flex items-center gap-2">
                <!-- Heroicons: check-circle -->
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#CA8A04" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                {proof}
              </div>
            </>
          ))}
        </div>
      </div>

      <!-- Image hero -->
      <div class="hidden lg:flex items-center justify-end">
        <div class="relative rounded-3xl overflow-hidden w-full" style="max-width: 460px; box-shadow: 0 32px 64px rgba(0,0,0,0.45);">
          <img
            src="/images/soulimane-farah.webp"
            alt={lang === 'fr' ? 'Soulimane Farah — Consultant SEO/GEO pharma à Montréal' : 'Soulimane Farah — Pharma SEO/GEO Consultant in Montréal'}
            width="920"
            height="700"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto block object-cover"
            style="aspect-ratio: 920/700;"
          />
          <!-- Overlay dégradé bas -->
          <div
            class="absolute inset-0"
            style="background: linear-gradient(160deg, rgba(15,23,42,0.08) 0%, rgba(15,23,42,0.55) 100%); border-radius: 1.5rem;"
            aria-hidden="true"
          ></div>
          <!-- Badge overlay -->
          <div
            class="absolute bottom-5 left-5 right-5 rounded-xl px-4 py-3 flex items-center gap-3"
            style="background: rgba(15,23,42,0.82); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.1);"
          >
            <div class="w-8 h-8 rounded-lg flex items-center justify-center shrink-0" style="background: rgba(202,138,4,0.2);">
              <!-- Heroicons: shield-check -->
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FCD34D" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs font-semibold" style="color: white; line-height: 1.3;">E-E-A-T · YMYL · Santé Canada</div>
              <div class="text-xs" style="color: rgba(255,255,255,0.5);">Conforme aux standards Google Santé</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
