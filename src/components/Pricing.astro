---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang; title?: string }
const { lang = 'fr', title } = Astro.props;
const t = useTranslations(lang).pricing;
---

<section id="tarifs" class="py-20 md:py-28" aria-labelledby="pricing-title">
  <div class="container">
    <div class="section-header">
      <span class="overline">{t.overline}</span>
      <h2 class="section-title" id="pricing-title">{title ?? t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8 items-stretch">
      {t.plans.map((plan) => (
        <article class={`card-pricing ${plan.featured ? 'featured' : ''}`} aria-label={`${lang === 'fr' ? 'Forfait' : 'Plan'} ${plan.name}`}>
          {plan.tag && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1.5 rounded-full text-xs font-bold text-white whitespace-nowrap" style="background: var(--color-cta);">{plan.tag}</span>
            </div>
          )}
          <div class="mb-6">
            <h3 class="mb-2" style="font-size: 1.125rem; color: var(--color-primary);">{plan.name}</h3>
            <p class="m-0" style="font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.6; max-width: none;">{plan.desc}</p>
          </div>
          <div class="flex items-end gap-1 mb-6 pb-6" style="border-bottom: 1px solid var(--color-border);">
            <span class="leading-none font-bold" style="font-family: var(--font-family-heading); font-size: 2.75rem; letter-spacing: -0.03em; color: var(--color-primary);">
              {plan.price} $
            </span>
            <span style="font-size: 0.9rem; color: var(--color-text-muted); padding-bottom: 0.4rem;">{plan.period}</span>
          </div>
          <ul class="flex flex-col gap-3 mb-8 flex-1 m-0 p-0 list-none">
            {plan.features.map(f => (
              <li class="flex items-start gap-2.5">
                <svg class="mt-0.5 shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke={plan.featured ? '#CA8A04' : '#059669'} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
                <span style="font-size: 0.875rem; color: var(--color-text-muted);">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class={`btn w-full justify-center mt-auto ${plan.featured ? 'btn-primary' : 'btn-outline'}`}>{plan.cta}</a>
        </article>
      ))}
    </div>

    <p class="text-center mt-10 text-sm" style="color: var(--color-text-subtle);">
      {t.note} <a href="#contact" class="font-semibold" style="color: var(--color-cta);">{t.noteLink}</a>.
    </p>
  </div>
</section>
