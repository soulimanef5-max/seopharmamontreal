---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).process;
---

<section id="processus" class="py-20 md:py-28" style="background: var(--color-surface-alt);" aria-labelledby="process-title">
  <div class="container">
    <div class="section-header">
      <span class="overline">{t.overline}</span>
      <h2 class="section-title" id="process-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="relative">
      <div class="hidden md:block absolute top-10 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, var(--color-border) 10%, var(--color-border) 90%, transparent); margin-inline: 12%;" aria-hidden="true"></div>

      <div class="grid md:grid-cols-3 gap-8">
        {t.steps.map((step) => (
          <article class="flex flex-col items-start bg-white rounded-2xl p-8" style="border: 1px solid var(--color-border); box-shadow: var(--shadow-card);">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl text-white font-bold text-base mb-6 shrink-0" style="background: var(--color-primary); font-family: var(--font-family-heading);" aria-hidden="true">
              {step.number}
            </div>
            <span class="text-xs font-semibold mb-3 px-2.5 py-1 rounded-full" style="background: var(--color-cta-light); color: var(--color-cta-hover);">{step.duration}</span>
            <h3 class="mb-3" style="font-size: 1.125rem; color: var(--color-primary);">{step.title}</h3>
            <p class="mb-6 flex-1" style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted); max-width: none;">{step.desc}</p>
            <div class="flex items-center gap-2 text-xs font-medium mt-auto pt-5 w-full" style="border-top: 1px solid var(--color-border); color: var(--color-primary);">
              <!-- Heroicons: document-arrow-down -->
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m.75 12 3 3m0 0 3-3m-3 3v-6m-1.5-9H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>
              </svg>
              {step.deliverable}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
