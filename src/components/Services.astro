---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).services;

// Heroicons v2 outline — magnifying-glass, map-pin, document-text
const icons = [
  `<path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/>`,
];
---

<section id="services" class="py-20 md:py-28" aria-labelledby="services-title">
  <div class="container">
    <div class="section-header">
      <span class="overline">{t.overline}</span>
      <h2 class="section-title" id="services-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {t.items.map((service, i) => (
        <article class="card-service flex flex-col" aria-label={service.title}>
          <span class="text-xs font-semibold mb-4 self-start px-3 py-1 rounded-full" style="background: var(--color-cta-light); color: var(--color-cta-hover); letter-spacing: 0.04em;">
            {service.tag}
          </span>
          <div class="w-11 h-11 rounded-xl flex items-center justify-center mb-4" style="background: var(--color-primary);" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons[i]} />
            </svg>
          </div>
          <h3 class="mb-3" style="font-size: 1.1875rem; color: var(--color-primary);">{service.title}</h3>
          <p class="mb-6 flex-1" style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted); max-width: none;">{service.desc}</p>
          <ul class="flex flex-col gap-2.5 mb-6 m-0 p-0 list-none">
            {service.features.map(f => (
              <li class="flex items-start gap-2.5">
                <!-- Heroicons: check-circle -->
                <svg class="mt-0.5 shrink-0" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#CA8A04" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                <span style="font-size: 0.875rem; color: var(--color-text-muted);">{f}</span>
              </li>
            ))}
          </ul>
          <a href="#contact" class="btn btn-outline w-full justify-center mt-auto">{t.cta}</a>
        </article>
      ))}
    </div>
  </div>
</section>
