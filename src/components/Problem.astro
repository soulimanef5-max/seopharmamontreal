---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).problem;

// Heroicons v2 outline — exclamation-triangle, eye-slash, clock
const icons = [
  `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>`,
];
---

<section class="py-20 md:py-28" style="background: var(--color-surface-alt);" aria-labelledby="problem-title">
  <div class="container">
    <div class="section-header">
      <span class="overline">{t.overline}</span>
      <h2 class="section-title" id="problem-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {t.pains.map((pain, i) => (
        <article class="card-service" aria-label={pain.title}>
          <div class="flex items-center justify-center w-12 h-12 rounded-xl mb-5" style="background: var(--color-cta-light);" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A16207" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons[i]} />
            </svg>
          </div>
          <h3 class="mb-3" style="font-size: 1.125rem; color: var(--color-primary);">{pain.title}</h3>
          <p class="m-0" style="font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-muted); max-width: none;">{pain.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
