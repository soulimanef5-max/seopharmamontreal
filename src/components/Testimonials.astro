---
// Section FAQ
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang?: Lang }
const { lang = 'fr' } = Astro.props;
const t = useTranslations(lang).faq;

// JSON-LD FAQPage — exploité par Google pour les rich snippets
const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type':    'FAQPage',
  mainEntity: t.items.map(item => ({
    '@type': 'Question',
    name:    item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text:    item.a,
    },
  })),
});
---

<script type="application/ld+json" set:html={faqSchema} />

<section
  id="faq"
  class="py-20 md:py-28"
  style="background: var(--color-surface-alt);"
  aria-labelledby="faq-title"
>
  <div class="container">
    <div class="section-header">
      <span class="overline">{t.overline}</span>
      <h2 class="section-title" id="faq-title">{t.title}</h2>
      <p class="section-lead">{t.lead}</p>
    </div>

    <div class="max-w-2xl mx-auto flex flex-col gap-3">
      {t.items.map((item) => (
        <details
          class="group rounded-xl overflow-hidden"
          style="background: var(--color-surface); border: 1px solid var(--color-border); box-shadow: var(--shadow-card);"
        >
          <summary
            class="flex items-center justify-between gap-4 p-6 cursor-pointer list-none select-none"
            style="font-family: var(--font-family-heading); font-weight: 600; font-size: 1rem; color: var(--color-primary);"
          >
            <span>{item.q}</span>
            <!-- Heroicons: chevron-down -->
            <svg
              class="shrink-0 transition-transform duration-300 group-open:rotate-180"
              width="18" height="18" viewBox="0 0 24 24"
              fill="none" stroke="var(--color-cta)" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
            </svg>
          </summary>
          <div
            class="px-6 pb-6"
            style="font-size: 0.9375rem; line-height: 1.75; color: var(--color-text-muted); border-top: 1px solid var(--color-border); padding-top: 1.25rem;"
          >
            {item.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
