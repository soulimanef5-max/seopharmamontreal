---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?:        Lang;
  title:        string;
  description:  string;
  pubDate:      Date;
  readingTime?: number;
  author?:      string;
  tags?:        string[];
  slug?:        string;
}

const {
  lang        = 'fr',
  title,
  description,
  pubDate,
  readingTime = 5,
  author      = 'Soulimane Farah',
  tags        = [],
  slug        = '',
} = Astro.props;

const t = useTranslations(lang);
const dateStr = pubDate.toLocaleDateString(lang === 'fr' ? 'fr-CA' : 'en-CA', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const canonicalUrl  = `https://seopharmamontreal.com${Astro.url.pathname}`;
const blogUrl       = lang === 'en' ? 'https://seopharmamontreal.com/en/blog/' : 'https://seopharmamontreal.com/blog/';
const homeUrl       = lang === 'en' ? 'https://seopharmamontreal.com/en/' : 'https://seopharmamontreal.com/';

// Slug extrait du pathname → /blog/mon-article/ → "mon-article"
const slugFromPath  = Astro.url.pathname.split('/').filter(Boolean).pop() ?? 'home';
const ogImageUrl    = `https://seopharmamontreal.com/og/${lang}/${slugFromPath}.png`;

// JSON-LD Article
const articleSchema = JSON.stringify({
  '@context':         'https://schema.org',
  '@type':            'Article',
  '@id':              canonicalUrl,
  headline:           title,
  description:        description,
  inLanguage:         lang === 'fr' ? 'fr-CA' : 'en-CA',
  url:                canonicalUrl,
  datePublished:      pubDate.toISOString(),
  dateModified:       pubDate.toISOString(),
  author: {
    '@type': 'Person',
    '@id':   'https://seopharmamontreal.com/#person',
    name:    author,
    url:     'https://seopharmamontreal.com',
  },
  publisher: {
    '@type':  'Organization',
    '@id':    'https://seopharmamontreal.com/#business',
    name:     'SEO Pharma Montréal',
    url:      'https://seopharmamontreal.com',
    logo: {
      '@type': 'ImageObject',
      url:     'https://seopharmamontreal.com/favicon.svg',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id':   canonicalUrl,
  },
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
});

// JSON-LD BreadcrumbList
const breadcrumbSchema = JSON.stringify({
  '@context':    'https://schema.org',
  '@type':       'BreadcrumbList',
  itemListElement: [
    {
      '@type':   'ListItem',
      position:  1,
      name:      lang === 'fr' ? 'Accueil' : 'Home',
      item:      homeUrl,
    },
    {
      '@type':   'ListItem',
      position:  2,
      name:      'Blog',
      item:      blogUrl,
    },
    {
      '@type':   'ListItem',
      position:  3,
      name:      title,
      item:      canonicalUrl,
    },
  ],
});
---

<Layout lang={lang} title={`${title} | SEO Pharma Montréal`} description={description} type="article" pubDate={pubDate} author={author} canonical={canonicalUrl} ogImage={ogImageUrl}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={articleSchema} />
    <script type="application/ld+json" set:html={breadcrumbSchema} />
  </Fragment>
  <Navbar lang={lang} />
  <main id="main-content">
    <!-- Fil d'Ariane (breadcrumb visible) -->
    <nav aria-label={lang === 'fr' ? 'Fil d\'ariane' : 'Breadcrumb'} class="py-3" style="background: var(--color-surface-alt); border-bottom: 1px solid var(--color-border);">
      <div class="container" style="max-width: var(--container-narrow);">
        <ol class="flex flex-wrap items-center gap-1.5 list-none m-0 p-0 text-xs" style="color: var(--color-text-muted);">
          <li>
            <a href={homeUrl} class="no-underline hover:underline" style="color: var(--color-text-muted);">
              {lang === 'fr' ? 'Accueil' : 'Home'}
            </a>
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li>
            <a href={blogUrl} class="no-underline hover:underline" style="color: var(--color-text-muted);">Blog</a>
          </li>
          <li aria-hidden="true" class="select-none">/</li>
          <li class="truncate max-w-xs font-medium" style="color: var(--color-primary);" aria-current="page">{title}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero article -->
    <header class="py-16 md:py-24" style="background: var(--color-primary);">
      <div class="container" style="max-width: var(--container-narrow);">
        <a
          href={lang === 'en' ? '/en/blog/' : '/blog/'}
          class="inline-flex items-center gap-2 text-sm no-underline mb-8 transition-opacity hover:opacity-70"
          style="color: rgba(255,255,255,0.55);"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
          {t.blog.backBlog}
        </a>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-5">
            {tags.map(tag => (
              <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background: rgba(202,138,4,0.15); color: #FCD34D;">{tag}</span>
            ))}
          </div>
        )}

        <h1 class="text-white mb-5" style="font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.2; letter-spacing: -0.025em;">{title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-sm" style="color: rgba(255,255,255,0.5);">
          <span class="flex items-center gap-1.5">
            <!-- Heroicons: clock -->
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-cta)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            {readingTime} {t.blog.minRead}
          </span>
          <span class="w-px h-4" style="background: rgba(255,255,255,0.2);" aria-hidden="true"></span>
          <time datetime={pubDate.toISOString()}>{dateStr}</time>
          <span class="w-px h-4" style="background: rgba(255,255,255,0.2);" aria-hidden="true"></span>
          <span>{author}</span>
        </div>
      </div>
    </header>

    <!-- Contenu article -->
    <article class="py-14 md:py-20">
      <div class="container" style="max-width: var(--container-narrow);">
        <div class="prose prose-slate prose-lg max-w-none"
          style="--tw-prose-headings: var(--color-primary); --tw-prose-links: var(--color-cta);">
          <slot />
        </div>

        <!-- CTA bas d'article -->
        <div
          class="mt-14 rounded-2xl p-8 text-center"
          style="background: var(--color-primary);"
        >
          <p class="font-bold mb-2" style="font-family: var(--font-family-heading); font-size: 1.25rem; color: white;">
            {lang === 'fr' ? 'Prêt à améliorer votre SEO santé ?' : 'Ready to improve your health SEO?'}
          </p>
          <p class="mb-6 text-sm" style="color: rgba(255,255,255,0.65);">
            {lang === 'fr'
              ? 'Obtenez une analyse préliminaire gratuite de votre site — réponse sous 24h.'
              : 'Get a free preliminary analysis of your site — response within 24h.'}
          </p>
          <a href={lang === 'en' ? '/en/#contact' : '/#contact'} class="btn btn-primary btn-lg">
            {lang === 'fr' ? 'Demander un audit gratuit' : 'Request a free audit'}
          </a>
        </div>
      </div>
    </article>
  </main>
  <Footer lang={lang} />
</Layout>
