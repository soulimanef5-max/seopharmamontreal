---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const lang = 'fr';
---

<Layout
  lang={lang}
  title="Page introuvable — SEO Pharma Montréal"
  description="Cette page n'existe pas ou a été déplacée. Retournez à l'accueil de SEO Pharma Montréal."
>
  <Navbar lang={lang} />
  <main id="main-content" class="flex flex-col items-center justify-center text-center py-32 px-6" style="min-height: 60vh;">

    <div class="mb-6 flex items-center justify-center w-20 h-20 rounded-2xl" style="background: rgba(202,138,4,0.1);" aria-hidden="true">
      <!-- Heroicons: exclamation-triangle -->
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#CA8A04" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
      </svg>
    </div>

    <p class="text-7xl font-bold mb-4" style="font-family: var(--font-family-heading); color: var(--color-primary); letter-spacing: -0.04em; line-height: 1;">404</p>
    <h1 class="mb-3" style="font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-primary); font-family: var(--font-family-heading);">
      Page introuvable
    </h1>
    <p class="mb-10 max-w-md" style="font-size: 1rem; line-height: 1.7; color: var(--color-text-muted);">
      Cette page n'existe pas ou a été déplacée. Vérifiez l'URL ou retournez à l'accueil.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href="/" class="btn btn-primary btn-lg">
        <!-- Heroicons: home -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Retour à l'accueil
      </a>
      <a href="/blog/" class="btn" style="border: 1.5px solid var(--color-border); color: var(--color-text-muted); padding: 0.75rem 1.5rem; border-radius: 0.5rem; font-weight: 600; font-size: 0.9375rem; text-decoration: none; transition: all .15s;">
        Voir le blog
      </a>
    </div>

    <!-- Liens utiles -->
    <div class="mt-14 pt-10 w-full max-w-sm" style="border-top: 1px solid var(--color-border);">
      <p class="text-xs mb-4 font-semibold uppercase tracking-widest" style="color: var(--color-text-muted);">Pages populaires</p>
      <nav aria-label="Pages utiles">
        <ul class="flex flex-col gap-2 list-none m-0 p-0">
          {[
            { href: '/#services', label: 'Services SEO/GEO Pharma' },
            { href: '/#tarifs',   label: 'Tarifs et forfaits' },
            { href: '/#contact',  label: 'Demander un audit gratuit' },
            { href: '/blog/',     label: 'Blog SEO Santé' },
          ].map(link => (
            <li>
              <a href={link.href} class="text-sm no-underline hover:underline flex items-center gap-2" style="color: var(--color-cta);">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </main>
  <Footer lang={lang} />
</Layout>
