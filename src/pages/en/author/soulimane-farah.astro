---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import ContactCTA from '../../../components/ContactCTA.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'en';
const title = 'Soulimane Farah — Pharma SEO/GEO Consultant in Montréal';
const description = "Who is Soulimane Farah? A SEO/GEO consultant specialized in pharma and health in Montréal. Industry background (Roche, Galderma), PAAB and Health Canada expertise, pharmaceutical quality assurance.";

const canonical = 'https://seopharmamontreal.com/en/author/soulimane-farah/';
const altCanonical = 'https://seopharmamontreal.com/auteur/soulimane-farah/';

const sameAs = [
  'https://www.linkedin.com/in/soulimanefarah/',
  'https://clutch.co/profile/seo-pharma-montr-al',
  'https://share.google/bcFz3bP5Wg1jXdP2A',
  'https://www.wikidata.org/wiki/Q140078557',
];

const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${canonical}#profilepage`,
  url: canonical,
  inLanguage: 'en-CA',
  name: title,
  mainEntity: {
    '@type': 'Person',
    '@id': 'https://seopharmamontreal.com/#person',
    name: 'Soulimane Farah',
    url: canonical,
    image: 'https://seopharmamontreal.com/images/soulimane-farah.webp',
    jobTitle: 'SEO/GEO Consultant — Pharma & Health',
    description: 'SEO/GEO consultant specialized in pharma and health in Montréal. 10 years at Roche in marketing and sales, then pharmaceutical quality assurance at Pharmascience and Galderma. PAAB, Health Canada and GEO expertise.',
    email: 'soulimane@seopharmamontreal.com',
    telephone: '+14389206377',
    worksFor: { '@type': 'Organization', '@id': 'https://seopharmamontreal.com/#business' },
    knowsAbout: ['SEO', 'GEO', 'LLMO', 'YMYL', 'E-E-A-T', 'PAAB', 'Health Canada', 'Pharma', 'GMP', 'Natural Health Products', 'Medical Devices'],
    alumniOf: { '@type': 'CollegeOrUniversity', name: 'Collège Gérald-Godin', url: 'https://www.college-gerald-godin.qc.ca' },
    hasCredential: [
      { '@type': 'EducationalOccupationalCredential', name: 'AEC Pharmaceutical Quality Assurance', credentialCategory: 'degree', recognizedBy: { '@type': 'CollegeOrUniversity', name: 'Collège Gérald-Godin' } },
      { '@type': 'EducationalOccupationalCredential', name: 'Google Analytics 4 Certified', credentialCategory: 'certificate', recognizedBy: { '@type': 'Organization', name: 'Google' } },
      { '@type': 'EducationalOccupationalCredential', name: 'AI-driven SEO Certified', credentialCategory: 'certificate' },
    ],
    sameAs,
  },
};
---

<Layout lang={lang} title={title} description={description} canonical={canonical} suppressHreflang={true}>
  <Fragment slot="head">
    <link rel="alternate" hreflang="fr-CA" href={altCanonical} />
    <link rel="alternate" hreflang="en-CA" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={altCanonical} />
    <script type="application/ld+json" set:html={JSON.stringify(profileSchema)} />
  </Fragment>

  <Navbar lang={lang} />

  <main id="main-content">

    <section class="relative overflow-hidden py-20 md:py-28" style="background: var(--color-primary);" aria-labelledby="author-title">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 65% 60% at 75% 30%, rgba(202,138,4,0.14) 0%, transparent 65%);" aria-hidden="true"></div>
      <div class="container relative">
        <div class="grid lg:grid-cols-[auto_1fr] gap-10 items-center">
          <img
            src="/images/soulimane-farah.webp"
            alt="Soulimane Farah, pharma SEO/GEO consultant in Montréal"
            width="180" height="180"
            class="rounded-2xl object-cover"
            style="width:180px; height:180px; box-shadow: 0 20px 40px rgba(0,0,0,0.4); border:2px solid rgba(202,138,4,0.4);"
            loading="eager" fetchpriority="high" decoding="async"
          />
          <div class="max-w-2xl">
            <div class="badge-authority">Author · Pharma SEO/GEO Consultant</div>
            <h1 id="author-title" class="text-white mb-4" style="font-size: clamp(2rem, 4.5vw, 3rem); line-height: 1.1; letter-spacing: -0.03em;">
              Soulimane Farah
            </h1>
            <p style="font-size: clamp(1rem, 1.8vw, 1.125rem); line-height: 1.7; color: rgba(255,255,255,0.75);">
              SEO/GEO consultant specialized in pharma and health in Montréal. After <strong style="color:rgba(255,255,255,0.92);">10 years at Roche in marketing and sales</strong>, then quality assurance at <strong style="color:rgba(255,255,255,0.92);">Pharmascience</strong> and <strong style="color:rgba(255,255,255,0.92);">Galderma</strong>, I combine pharma marketing insight and regulatory rigour with SEO and AI visibility — a rare dual expertise in Canada.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24" aria-labelledby="bio-title">
      <div class="container" style="max-width: var(--container-narrow);">
        <h2 class="section-title" id="bio-title">My background</h2>
        <div style="font-size:1.0625rem; line-height:1.8; color:var(--color-text); margin-top:1.5rem;">
          <p style="margin-bottom:1.25rem;">
            My background is doubly rooted in pharma. I spent <strong>10 years at Roche, in marketing and sales</strong> — so I've lived the day-to-day of the very teams I now advise: product launches, regulatory constraints, approval cycles, pressure on visibility.
          </p>
          <p style="margin-bottom:1.25rem;">
            I then specialized in <strong>pharmaceutical quality assurance</strong>, at <strong>Pharmascience</strong> and then <strong>Galderma</strong>, where I was trained to a level of rigour — content validation, compliance, governance — that generalist SEO agencies never acquire. This dual perspective, <strong>marketing and regulatory quality</strong>, is my unique edge.
          </p>
          <p style="margin-bottom:1.25rem;">
            In practice, I natively understand the <a href="https://www.paab.ca" target="_blank" rel="noopener" style="color:var(--color-cta); font-weight:600;">PAAB</a> and <a href="https://www.canada.ca/en/health-canada.html" target="_blank" rel="noopener" style="color:var(--color-cta); font-weight:600;">Health Canada</a> framework, the separation between branded and unbranded content, and the ban on direct-to-consumer (DTC) advertising — and I structure SEO strategies accordingly from the start.
          </p>
          <p>
            On the education side, I hold an <strong>AEC in Pharmaceutical Quality Assurance</strong> (Collège Gérald-Godin), complemented by <strong>Google Analytics 4</strong> and <strong>AI-driven SEO</strong> certifications. Today, I help pharmaceutical, biotech, medical device and natural health product companies improve their visibility on Google and in generative AI (ChatGPT, Perplexity, Google AI Overviews), in both French and English.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24" style="background: var(--color-surface, #f8fafc);">
      <div class="container">
        <div class="grid md:grid-cols-2 gap-10">
          <div>
            <h2 class="section-title">Areas of expertise</h2>
            <ul style="margin-top:1.25rem; line-height:2; color:var(--color-text); list-style:none; padding:0;">
              <li>✓ Technical SEO & YMYL / E-E-A-T content</li>
              <li>✓ PAAB & Health Canada regulatory compliance</li>
              <li>✓ GEO — visibility in generative AI</li>
              <li>✓ Natural health products (NPN) & medical devices</li>
              <li>✓ Local health SEO (Montréal / Québec)</li>
              <li>✓ Bilingual FR / EN strategy</li>
            </ul>
          </div>
          <div>
            <h2 class="section-title">Education & certifications</h2>
            <ul style="margin-top:1.25rem; line-height:2; color:var(--color-text); list-style:none; padding:0;">
              <li>🎓 AEC Pharmaceutical Quality Assurance — Collège Gérald-Godin</li>
              <li>📊 Google Analytics 4 Certified</li>
              <li>🤖 AI-driven SEO Certified</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24">
      <div class="container" style="max-width: var(--container-narrow);">
        <h2 class="section-title">Find me elsewhere</h2>
        <div class="flex flex-wrap gap-4" style="margin-top:1.25rem;">
          <a href="https://www.linkedin.com/in/soulimanefarah/" target="_blank" rel="noopener" class="btn btn-ghost">LinkedIn</a>
          <a href="https://clutch.co/profile/seo-pharma-montr-al" target="_blank" rel="noopener" class="btn btn-ghost">Clutch</a>
          <a href="https://share.google/bcFz3bP5Wg1jXdP2A" target="_blank" rel="noopener" class="btn btn-ghost">Google Business Profile</a>
          <a href="https://www.wikidata.org/wiki/Q140078557" target="_blank" rel="noopener" class="btn btn-ghost">Wikidata</a>
        </div>
        <p style="margin-top:2rem; font-size:0.95rem; color:var(--color-text-muted);">
          → Read my articles on the <a href="/en/blog/" style="color:var(--color-cta); font-weight:600;">SEO Pharma Montréal blog</a>, or discover my <a href="/en/seo-pharma/" style="color:var(--color-cta); font-weight:600;">full consulting approach</a>.
        </p>
      </div>
    </section>

    <ContactCTA lang={lang} />
  </main>

  <Footer lang={lang} />
</Layout>
